# Vercel Postgres — set automatically when Vercel Postgres is attached
POSTGRES_URL=
POSTGRES_PRISMA_URL=
POSTGRES_URL_NON_POOLING=
POSTGRES_USER=
POSTGRES_HOST=
POSTGRES_PASSWORD=
POSTGRES_DATABASE=

# Vercel Blob — set automatically when Vercel Blob is attached
BLOB_READ_WRITE_TOKEN=

# CORS — explicit production URL (optional, falls back to VERCEL_URL)
APP_URL=

# init-db protection — set a secret and pass as X-Init-Secret header to /api/init-db
INIT_SECRET=
